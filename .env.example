# Optional: local database path
# DATABASE_URL=sqlite:///./aawo.db

# App default timezone
AAWO_TIMEZONE=Asia/Seoul

# OpenAI integration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_ASSISTANT_MODEL=gpt-5-mini
OPENAI_NLI_MODEL=gpt-5-mini
OPENAI_EXTRACTION_MODEL=gpt-5-mini
OPENAI_FALLBACK_MODEL=gpt-5-mini
OPENAI_TEMPERATURE=0.2
OPENAI_ASSISTANT_TEMPERATURE=0.1
OPENAI_ASSISTANT_TIMEOUT_SECONDS=14
ASSISTANT_LLM_ONLY=true
OPENAI_TIMEOUT_SECONDS=12

# Microsoft Graph (Outlook/To Do) OAuth
MS_TENANT_ID=common
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_REDIRECT_URI=http://localhost:8000/api/graph/auth/callback
MS_SCOPES=User.Read offline_access Calendars.ReadWrite Tasks.ReadWrite Mail.Read
MS_WEBHOOK_NOTIFICATION_URL=
MS_WEBHOOK_LIFECYCLE_URL=
MS_WEBHOOK_CLIENT_STATE=aawo-webhook-state
MS_WEBHOOK_RESOURCE=/me/events
MS_WEBHOOK_CHANGE_TYPE=created,updated,deleted
MS_SUBSCRIPTION_TTL_MINUTES=120

# Background sync worker
SYNC_WORKER_ENABLED=true
SYNC_WORKER_POLL_SECONDS=5
SYNC_WORKER_OUTBOX_INTERVAL_SECONDS=15
SYNC_WORKER_OUTBOX_BATCH_SIZE=20
SYNC_WORKER_RENEW_CHECK_SECONDS=60
SYNC_WORKER_RENEW_MARGIN_MINUTES=20
SYNC_WORKER_MAIL_DELTA_INTERVAL_SECONDS=90
SYNC_WORKER_MAIL_UNREAD_ONLY=true

# Scheduler (OR-Tools CP-SAT)
SCHEDULER_CPSAT_ENABLED=true
SCHEDULER_CPSAT_TIMEOUT_SECONDS=3.0
SCHEDULER_CPSAT_MAX_CANDIDATES_PER_TASK=80
